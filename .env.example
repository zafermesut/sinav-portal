# ===========================================
# ZORUNLU DEĞİŞKENLER
# ===========================================

# Payload CMS gizli anahtarı (en az 32 karakter)
# Güçlü bir anahtar üretmek için: openssl rand -base64 32
PAYLOAD_SECRET=your-super-secret-key-min-32-chars-change-this

# PostgreSQL bağlantı URI
# Neon ücretsiz plan: https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require

# Next.js public URL (Vercel deploy sonrası otomatik gelir)
# Lokal geliştirme için:
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ===========================================
# OPSİYONEL
# ===========================================

# Node ortamı
NODE_ENV=development
